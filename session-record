#!/usr/bin/env bash
#
# session-record — Record terminal sessions using macOS `script`
#
# Usage:
#   session-record start [name]     Start recording (name is optional, defaults to timestamp)
#   session-record stop             Stop the current recording (just type 'exit' or Ctrl-D)
#   session-record list             List all recorded sessions
#   session-record stream <name>    Stream a session live from the log
#   session-record attach [name]    Attach read-only to the active/live session
#   session-record show <name>      Show a recorded session (cleaned of ANSI codes)
#   session-record raw <name>       Show raw recording
#   session-record replay <name>    Replay a session in real time
#   session-record delete <name>    Delete a session recording
#   session-record clean            Delete sessions older than 30 days
#
# Captures terminal sessions with readable transcripts by default.
# Set SESSION_RECORD_CAPTURE_KEYS=1 to also capture raw keystrokes.
# Logs stored in ~/.session-logs/

set -euo pipefail

LOG_DIR="$HOME/.session-logs"
ACTIVE_FILE="$LOG_DIR/.active"
ACTIVE_PID_FILE="$LOG_DIR/.active.pid"

mkdir -p "$LOG_DIR"

# ─── Helpers ────────────────────────────────────────────────────────────────

die()  { echo "session-record: error: $*" >&2; exit 1; }
info() { echo "session-record: $*"; }

capture_keys_enabled() {
  local value="${SESSION_RECORD_CAPTURE_KEYS:-0}"
  [[ "$value" == "1" || "$value" == "true" || "$value" == "yes" ]]
}

strip_ansi() {
  # Strip ANSI escape sequences, carriage returns, and collapse whitespace
  perl -pe '
    s/\e\[[0-9;?]*[a-zA-Z]//g;
    s/\e\[[0-9;?]*[~^@]//g;
    s/\e\][^\007]*\007//g;
    s/\e\][^\033]*\e\\//g;
    s/\e[P^_][^\033]*\e\\//g;
    s/\e[\(\)][A-Z0-9]//g;
    s/\e[=>NOMDEHc78]//g;
    s/\e[^\[\]0-9]//g;
    s/\r//g;
  '
}

session_file() {
  echo "$LOG_DIR/${1}.log"
}

cleanup_active_state() {
  rm -f "$ACTIVE_FILE" "$ACTIVE_PID_FILE"
}

active_pid() {
  [[ -f "$ACTIVE_PID_FILE" ]] || return 1
  cat "$ACTIVE_PID_FILE"
}

is_pid_running() {
  local pid="${1:-}"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

refresh_active_state() {
  [[ -f "$ACTIVE_FILE" ]] || return 0

  local name pid logfile
  name=$(cat "$ACTIVE_FILE")
  logfile=$(session_file "$name")
  pid=$(active_pid 2>/dev/null || true)

  if [[ -n "$pid" ]] && is_pid_running "$pid"; then
    return 0
  fi

  if [[ -f "$logfile" ]] && tail -n 1 "$logfile" 2>/dev/null | grep -q '^Script done on '; then
    cleanup_active_state
    return 0
  fi

  cleanup_active_state
}

# ─── Commands ───────────────────────────────────────────────────────────────

cmd_start() {
  local name="${1:-$(date '+%Y-%m-%d_%H%M%S')}"
  local logfile
  logfile=$(session_file "$name")

  refresh_active_state

  # Check if already recording
  if [[ -f "$ACTIVE_FILE" ]]; then
    local current
    current=$(cat "$ACTIVE_FILE")
    die "already recording session '$current'. Type 'exit' or Ctrl-D to stop it first."
  fi

  # Store active session name
  echo "$name" > "$ACTIVE_FILE"
  echo "$$" > "$ACTIVE_PID_FILE"
  trap cleanup_active_state EXIT INT TERM

  info "recording started → $name"
  info "log file: $logfile"
  if capture_keys_enabled; then
    info "raw keystrokes and terminal output will be captured"
  else
    info "terminal output will be captured"
    info "set SESSION_RECORD_CAPTURE_KEYS=1 if you need raw keystroke capture"
  fi
  info "type 'exit' or press Ctrl-D to stop recording"
  echo ""

  # -F  flush after every write (so we don't lose data on crash)
  # -q  quiet (no "Script started/done" banners in the terminal)
  # -k  capture raw keystrokes as well as output; useful for forensics but can
  #     make cleaned transcripts hard to read because cursor edits get flattened
  # On exit, clean up the active marker
  if capture_keys_enabled; then
    script -Fkq "$logfile"
  else
    script -Fq "$logfile"
  fi

  # script has exited — session is done
  cleanup_active_state

  echo ""
  info "recording stopped → $name"
  info "log file: $logfile ($(du -h "$logfile" | cut -f1))"
  info "view cleaned: session-record show $name"
}

cmd_stop() {
  refresh_active_state

  if [[ ! -f "$ACTIVE_FILE" ]]; then
    info "no active recording. Nothing to stop."
    info "if you're inside a recording, just type 'exit' or press Ctrl-D."
    return 0
  fi

  local name
  name=$(cat "$ACTIVE_FILE")
  info "active session: '$name'"
  info "to stop it, type 'exit' or press Ctrl-D in the recorded shell."
  info "the recording shell is the innermost shell you're in."
}

cmd_list() {
  local found=false
  local active=""
  refresh_active_state
  [[ -f "$ACTIVE_FILE" ]] && active=$(cat "$ACTIVE_FILE")

  for logfile in "$LOG_DIR"/*.log; do
    [[ -f "$logfile" ]] || continue
    found=true
    local name
    name=$(basename "$logfile" .log)
    local size
    size=$(du -h "$logfile" | cut -f1)
    local modified
    modified=$(stat -f '%Sm' -t '%Y-%m-%d %H:%M' "$logfile")

    local marker=""
    [[ "$name" == "$active" ]] && marker=" ← RECORDING"

    printf "  %-30s %8s  %s%s\n" "$name" "$size" "$modified" "$marker"
  done

  if [[ "$found" == false ]]; then
    info "no recordings found in $LOG_DIR"
  fi
}

cmd_show() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "usage: session-record show <name>"

  local logfile
  logfile=$(session_file "$name")
  [[ -f "$logfile" ]] || die "no recording found: $name"

  strip_ansi < "$logfile"
}

cmd_stream() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "usage: session-record stream <name>"

  local logfile
  logfile=$(session_file "$name")
  [[ -f "$logfile" ]] || die "no recording found: $name"

  info "streaming session '$name' (Ctrl-C to stop)"
  tail -f "$logfile" | strip_ansi
}

cmd_attach() {
  refresh_active_state

  local name="${1:-}"
  if [[ -z "$name" ]]; then
    [[ -f "$ACTIVE_FILE" ]] || die "no active recording. Usage: session-record attach [name]"
    name=$(cat "$ACTIVE_FILE")
  fi

  local logfile
  logfile=$(session_file "$name")
  [[ -f "$logfile" ]] || die "no recording found: $name"

  info "attached read-only to session '$name' (Ctrl-C to stop)"
  tail -f "$logfile" | strip_ansi
}

cmd_raw() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "usage: session-record raw <name>"

  local logfile
  logfile=$(session_file "$name")
  [[ -f "$logfile" ]] || die "no recording found: $name"

  cat "$logfile"
}

cmd_replay() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "usage: session-record replay <name>"

  local logfile
  logfile=$(session_file "$name")
  [[ -f "$logfile" ]] || die "no recording found: $name"

  info "replaying session '$name' (Ctrl-C to stop)"
  echo ""
  # -p plays back, -d disables real-time delays
  script -p "$logfile"
}

cmd_delete() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "usage: session-record delete <name>"

  local logfile
  logfile=$(session_file "$name")
  [[ -f "$logfile" ]] || die "no recording found: $name"

  rm -f "$logfile"
  info "deleted: $name"
}

cmd_clean() {
  local days="${1:-30}"
  local count=0

  while IFS= read -r -d '' logfile; do
    local name
    name=$(basename "$logfile" .log)
    rm -f "$logfile"
    info "deleted: $name"
    count=$((count + 1))
  done < <(find "$LOG_DIR" -name "*.log" -mtime +"$days" -print0 2>/dev/null)

  info "cleaned $count session(s) older than $days days"
}

cmd_help() {
  cat <<'EOF'
session-record — Record terminal sessions using macOS `script`

Usage:
  session-record start [name]     Start recording (name defaults to timestamp)
  session-record stop             Show how to stop the current recording
  session-record list             List all recorded sessions
  session-record stream <name>    Stream a session live from the log
  session-record attach [name]    Attach read-only to the active/live session
  session-record show <name>      Show a session with ANSI codes stripped
  session-record raw <name>       Show raw session recording
  session-record replay <name>    Replay a session
  session-record delete <name>    Delete a session
  session-record clean [days]     Delete sessions older than N days (default 30)

Captures everything: commands, output, SSH, telnet, tmux, interactive programs.
Logs stored in ~/.session-logs/

To stop a recording, type 'exit' or press Ctrl-D in the recorded shell.
EOF
}

# ─── Main ───────────────────────────────────────────────────────────────────

cmd="${1:-}"
shift 2>/dev/null || true

case "$cmd" in
  start)   cmd_start "$@" ;;
  stop)    cmd_stop ;;
  list)    cmd_list ;;
  stream)  cmd_stream "$@" ;;
  attach)  cmd_attach "$@" ;;
  show)    cmd_show "$@" ;;
  raw)     cmd_raw "$@" ;;
  replay)  cmd_replay "$@" ;;
  delete)  cmd_delete "$@" ;;
  clean)   cmd_clean "$@" ;;
  help|--help|-h) cmd_help ;;
  "")      cmd_help ;;
  *)       die "unknown command: $cmd. Run 'session-record help' for usage." ;;
esac
